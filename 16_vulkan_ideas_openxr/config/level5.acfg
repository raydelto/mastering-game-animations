  ssao-enabled: false
  ssao-radius: 5
  ssao-bias: 0.2
  ssao-exponent: 4
  ssao-blur-enabled: false
  ssao-blur-radius: 3
  shadowmap-enabled: false
  shadowmap-split-lambda: 0.95
  shadowmap-constant-bias: 1.25
  shadowmap-slope-bias: 1.75
  shadowmap-pcf-enabled: false
  shadowmap-pcf-scale: 0.1
  shadowmap-pcf-range: 3
  dynlight-shadowmap-constant-bias: 1.25
  dynlight-shadowmap-slope-bias: 1.75

levels:
