# Application viewer config file
version: 12.0

settings:
  near-clip-plane: 0.446
  far-clip-plane: 1000
  orth-nearfar-clip-plane: 40
  selected-model: 2
  selected-instance: 0
  selected-camera: 0
  selected-level: 1
  selected-dynamic-light: 0
  highlight-selection: false
  collision-enabled: 2
  interaction-enabled: true
  interaction-min-range: 1.5
  interaction-max-range: 10
  interaction-fov: 45
  gravity-enabled: true
  level-collision-ground-slope: 40
  level-collision-max-stairstep-height: 1.75
